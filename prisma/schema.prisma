generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ ENUMS ============

enum UserRole {
  ADMIN
  PANELIST
  STUDENT
}

enum InterviewMode {
  ONLINE
  OFFLINE
  ON_PAPER
  GOOGLE_DOCS
  CODING_PLATFORM
  HYBRID
}

enum RoundType {
  ONLINE_ASSESSMENT
  TECHNICAL_1
  TECHNICAL_2
  TECHNICAL_3
  SYSTEM_DESIGN
  MANAGERIAL
  HR
  DIRECTOR
  BEHAVIORAL
  CODING_ROUND
  OTHER
}

enum RoundOutcome {
  CLEARED
  REJECTED
  PENDING
  NO_SHOW
}

enum Branch {
  CSE
  IT
  ECE
  EEE
  MECH
  CIVIL
  CHEM
  AI_ML
  OTHER
}

enum ImportStatus {
  QUEUED
  EXTRACTING
  READY_FOR_REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

enum SubmissionStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// ============ CORE ============

model Company {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  logoUrl     String?
  websiteUrl  String?
  description String?
  createdAt   DateTime    @default(now())
  interviews  Interview[]
  jobs        Job[]
  intelligenceViews IntelligenceView[]
  ctcJson     Json?
  ctc         Float?
  ctcMin      Float?
  ctcMax      Float?

  @@index([slug])
  @@index([ctc])
  @@index([ctcMin])
  @@index([ctcMax])
}

model Job {
  id               String      @id @default(cuid())
  externalJobId    String      @unique
  company          Company     @relation(fields: [companyId], references: [id])
  companyId        String
  role             String
  techStack        String?
  optionalSkills   String?
  ctcMin           Float?
  ctcMax           Float?
  openings         Int?
  location         String?
  jobType          String?
  product          String?
  hubspotUrl       String?
  sourceCategory   String?
  enteredBy        String?
  enteredAt        DateTime?
  interviewProcess String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  interviews       Interview[]

  @@index([companyId])
  @@index([role])
}

model RoleLevel {
  id         String      @id @default(cuid())
  name       String      @unique
  slug       String      @unique
  createdAt  DateTime    @default(now())
  interviews Interview[]
}

model Interview {
  id                  String     @id @default(cuid())
  company             Company    @relation(fields: [companyId], references: [id])
  companyId           String
  job                 Job?       @relation(fields: [jobId], references: [id])
  jobId               String?    @unique
  role                String
  roleLevel           RoleLevel  @relation(fields: [roleLevelId], references: [id])
  roleLevelId         String
  year                Int
  totalSelected       Int?
  biggestTip          String?
  candidateCgpa       Float?
  candidateBranch     Branch?
  candidateGradYear   Int?
  candidateBackground String?
  sourceCategory      String?
  externalSource      String?
  interviewProcess    String?
  publishedAt         DateTime   @default(now())
  createdBy           User       @relation(fields: [createdById], references: [id])
  createdById         String

  rounds              Round[]
  assets              Asset[]
  bookmarks           Bookmark[]
  importedFrom        ImportRow? @relation("ImportToInterview")

  @@index([companyId, roleLevelId, year])
  @@index([roleLevelId])
  @@index([year])
  @@index([publishedAt])
  @@index([candidateBranch])
  @@index([jobId])
}

model Round {
  id                String           @id @default(cuid())
  interview         Interview        @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId       String
  roundNumber       Int
  roundName         String
  roundType         RoundType
  durationMinutes   Int?
  mode              InterviewMode
  numInterviewers   Int?
  interviewStyle    String?
  outcome           RoundOutcome
  keyLearnings      String?
  assessmentPattern String?
  pocRemarks        String?
  recordingUrl      String?
  transcriptUrl     String?

  topicCoverages  TopicCoverage[]
  assets          Asset[]

  @@index([interviewId, roundNumber])
  @@index([roundType])
}

// ============ TOPIC AREAS & SUB-TOPICS ============

model TopicArea {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())

  subTopics      SubTopic[]
  topicCoverages TopicCoverage[]

  @@index([sortOrder])
}

model SubTopic {
  id            String           @id @default(cuid())
  name          String
  slug          String
  topicArea     TopicArea        @relation(fields: [topicAreaId], references: [id])
  topicAreaId   String
  createdAt     DateTime         @default(now())

  entries       SubTopicEntry[]

  @@unique([slug, topicAreaId])
  @@unique([name, topicAreaId])
  @@index([topicAreaId])
}

model TopicCoverage {
  id              String          @id @default(cuid())
  round           Round           @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId         String
  topicArea       TopicArea       @relation(fields: [topicAreaId], references: [id])
  topicAreaId     String
  subTopicCount   Int             @default(0)
  orderIndex      Int             @default(0)

  entries         SubTopicEntry[]

  @@index([roundId, orderIndex])
  @@index([topicAreaId])
}

model SubTopicEntry {
  id                 String        @id @default(cuid())
  topicCoverage      TopicCoverage @relation(fields: [topicCoverageId], references: [id], onDelete: Cascade)
  topicCoverageId    String
  subTopic           SubTopic      @relation(fields: [subTopicId], references: [id])
  subTopicId         String
  orderIndex         Int           @default(0)
  exactQuestionText  String?
  referenceUrl       String?
  externalQuestionId String?       @unique
  questionType       String?
  difficulty         Difficulty?
  skillsAssessed     String?

  @@index([topicCoverageId, orderIndex])
  @@index([subTopicId])
  @@index([difficulty])
}

// ============ ASSETS ============

model Asset {
  id          String     @id @default(cuid())
  interview   Interview? @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId String?
  round       Round?     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId     String?
  kind        String
  url         String
  label       String?
  uploadedAt  DateTime   @default(now())

  @@index([interviewId])
  @@index([roundId])
}

// ============ USERS ============

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  ssoUserId    String?       @unique
  name         String?
  role         UserRole      @default(STUDENT)
  branch       Branch?
  gradYear     Int?
  avatarUrl    String?
  onboardedAt  DateTime?
  createdAt    DateTime      @default(now())

  interviews   Interview[]
  bookmarks    Bookmark[]
  importBatches ImportBatch[]
  submissions  ExperienceSubmission[]
  intelligenceViews IntelligenceView[]
}

model IntelligenceView {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  viewDate  DateTime @db.Date
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, viewDate])
  @@index([userId, viewDate])
}

// ============ STUDENT-SUBMITTED EXPERIENCES ============

// A candidate-submitted interview experience awaiting admin review. It is NEVER
// public data — only an admin action (publishSubmission) creates the real
// Interview tree. Keeps unreviewed content fully separate from the live catalog.
model ExperienceSubmission {
  id                   String           @id @default(cuid())
  submittedBy          User             @relation(fields: [submittedById], references: [id])
  submittedById        String
  companyName          String
  role                 String
  year                 Int
  payload              Json
  status               SubmissionStatus @default(PENDING)
  reviewNotes          String?
  reviewedById         String?
  reviewedAt           DateTime?
  publishedInterviewId String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([submittedById])
}

model Bookmark {
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId String
  createdAt   DateTime  @default(now())

  @@id([userId, interviewId])
  @@index([interviewId])
}

// ============ CSV IMPORT ============

model ImportBatch {
  id           String      @id @default(cuid())
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])
  uploadedById String
  filename     String
  totalRows    Int
  createdAt    DateTime    @default(now())

  rows         ImportRow[]

  @@index([uploadedById, createdAt])
}

model ImportRow {
  id                    String       @id @default(cuid())
  batch                 ImportBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId               String
  rowIndex              Int
  companyName           String
  status                ImportStatus @default(QUEUED)
  rawCsvJson            Json
  extractedJson         Json?
  extractionTokens      Int?
  extractionCostUsd     Float?
  errorMessage          String?
  publishedInterview    Interview?   @relation("ImportToInterview", fields: [publishedInterviewId], references: [id])
  publishedInterviewId  String?      @unique
  reviewedAt            DateTime?
  updatedAt             DateTime     @updatedAt

  @@index([batchId, status])
  @@index([status])
}

// ============ FEATURE FLAGS ============

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}
